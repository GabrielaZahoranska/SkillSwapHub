# On Render: add PYTHON_VERSION = 3.11.9 in the Web Service Environment
# so the build uses Python 3.11 (matches local dev). Repo also has runtime.txt.

# Copy this file to .env for local development (never commit real .env).
# Do NOT put ON_RENDER or DATABASE_URL here for normal local work — those are Render-only.

SECRET_KEY=your-long-random-string-here
# DEBUG=True
# ALLOWED_HOSTS=localhost,127.0.0.1

# Optional Render-style database URL locally (normally leave unset and use local Postgres):
# DATABASE_URL=
